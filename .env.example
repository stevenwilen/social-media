# Copy this file to `.env` and fill in real values. `.env` is gitignored — never commit secrets.

# FlexMLS / Spark API — non-expiring Bearer token for Veronica's "Own Data" plan.
# Obtain via sparkplatform.com (see the `flexmls` skill for the full steps).
FLEXMLS_TOKEN=

# Optional: the Spark API feed ID (OAuth key) issued alongside the token.
FLEXMLS_FEED_ID=
